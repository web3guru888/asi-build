# Kenny AGI Blockchain Audit Trail Environment Variables

# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Security Keys
JWT_SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Blockchain Networks

# Ethereum Mainnet
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
ETHEREUM_PRIVATE_KEY=0x...

# Ethereum Goerli Testnet
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_PROJECT_ID
GOERLI_PRIVATE_KEY=0x...

# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-rpc.com/
POLYGON_PRIVATE_KEY=0x...

# Polygon Mumbai Testnet
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com/
MUMBAI_PRIVATE_KEY=0x...

# IPFS Configuration
IPFS_API_URL=/dns/localhost/tcp/5001/http
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# IPFS Pinning Services

# Pinata
PINATA_ENABLED=false
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key

# Infura IPFS
INFURA_IPFS_ENABLED=false
INFURA_PROJECT_ID=your-infura-project-id
INFURA_PROJECT_SECRET=your-infura-project-secret

# Database Configuration

# PostgreSQL
POSTGRES_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kenny_audit_trail
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# Redis
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Monitoring

# Prometheus
PROMETHEUS_ENABLED=false

# Sentry
SENTRY_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Logging
LOG_FILE=logs/audit_trail.log

# Development Settings (for local development)
DEV_AUTO_RELOAD=true
DEV_DEBUG_QUERIES=true
DEV_MOCK_BLOCKCHAIN=false
DEV_MOCK_IPFS=false

# Testing
TEST_NETWORK=hardhat
TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
TEST_IPFS_NODE=localhost:5001