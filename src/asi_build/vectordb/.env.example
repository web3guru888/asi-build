# Kenny Vector Database Environment Variables
# Copy this file to .env and fill in your actual API keys and configuration

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east1-aws
PINECONE_INDEX_NAME=kenny-vectors

# Weaviate Configuration
WEAVIATE_HOST=localhost
WEAVIATE_API_KEY=your_weaviate_api_key_here

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=kenny-collection

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_API_KEY=your_openai_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# System Configuration
KENNY_VECTORDB_ENV=development  # development, production, high_performance
KENNY_VECTORDB_LOG_LEVEL=INFO
KENNY_VECTORDB_CACHE_DIR=./embeddings_cache