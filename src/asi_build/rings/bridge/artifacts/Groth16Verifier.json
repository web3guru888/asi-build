ts\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256[2]\",\"name\":\"a\",\"type\":\"uint256[2]\"},{\"internalType\":\"uint256[2][2]\",\"name\":\"b\",\"type\":\"uint256[2][2]\"},{\"internalType\":\"uint256[2]\",\"name\":\"c\",\"type\":\"uint256[2]\"},{\"internalType\":\"uint256[]\",\"name\":\"input\",\"type\":\"uint256[]\"}],\"name\":\"verify\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes\",\"name\":\"proof\",\"type\":\"bytes\"},{\"internalType\":\"bytes32[]\",\"name\":\"publicInputs\",\"type\":\"bytes32[]\"}],\"name\":\"verifyProof\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"ASI:BUILD \\u2014 Rings\\u2194Ethereum Bridge\",\"details\":\"On-chain Groth16 zero-knowledge proof verifier over the BN254      (alt_bn128) curve, using Ethereum precompiles:        \\u2022 ecAdd      \\u2014 address 0x06        \\u2022 ecMul      \\u2014 address 0x07        \\u2022 ecPairing  \\u2014 address 0x08      The verification key is set once at deployment and is immutable.      Two entry points are provided:        1. `verify(a, b, c, input)` \\u2014 low-level, accepts decoded points.        2. `verifyProof(proof, publicInputs)` \\u2014 high-level, accepts           ABI-encoded proof bytes and a public-inputs array.      This contract follows the standard pattern produced by snarkjs and      circom tooling.\",\"kind\":\"dev\",\"methods\":{\"constructor\":{\"details\":\"IC must have at least 2 elements (IC[0] + at least one input).\",\"params\":{\"alpha1\":\"G1 component of the verification key.\",\"beta2\":\"G2 component of the verification key.\",\"delta2\":\"G2 component of the verification key.\",\"gamma2\":\"G2 component of the verification key.\",\"ic\":\"Array of G1 points (IC[0..n] where n = public inputs).\"}},\"getInputCount()\":{\"returns\":{\"_0\":\"The number of public inputs (IC.length - 1).\"}},\"verify(uint256[2],uint256[2][2],uint256[2],uint256[])\":{\"params\":{\"a\":\"G1 proof element \\u03c0_A as [x, y].\",\"b\":\"G2 proof element \\u03c0_B as [[x_imag, x_real], [y_imag, y_real]].\",\"c\":\"G1 proof element \\u03c0_C as [x, y].\",\"input\":\"Public inputs array (length must equal IC.length - 1).\"},\"returns\":{\"_0\":\"True if the proof is valid, false otherwise.\"}},\"verifyProof(bytes,bytes32[])\":{\"details\":\"The proof bytes are decoded as:        abi.encode(uint256[2], uint256[2][2], uint256[2])      Each publicInput bytes32 is cast to uint256.\",\"params\":{\"proof\":\"ABI-encoded (uint256[2] a, uint256[2][2] b, uint256[2] c).\",\"publicInputs\":\"Array of public input values as bytes32.\"},\"returns\":{\"_0\":\"True if the proof is valid, false otherwise.\"}}},\"stateVariables\":{\"PRIME_Q\":{\"details\":\"BN254 curve order (prime subgroup order).\"},\"_vk\":{\"details\":\"The immutable verification key, set in the constructor.\"}},\"title\":\"Groth16Verifier\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"getInputCount()\":{\"notice\":\"Return the number of public inputs expected by this verifier.\"},\"verify(uint256[2],uint256[2][2],uint256[2],uint256[])\":{\"notice\":\"Verify a Groth16 proof given decoded elliptic-curve points         and public inputs.\"},\"verifyProof(bytes,bytes32[])\":{\"notice\":\"High-level entry point: verify an ABI-encoded proof with         public inputs provided as bytes32 array.\"}},\"notice\":\"The BN254 curve order is:         p = 21888242871839275222246405745257275088696311157297823662689037894645226208583         (used for scalar-field checks)\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/Groth16Verifier.sol\":\"Groth16Verifier\"},\"evmVersion\":\"shanghai\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs