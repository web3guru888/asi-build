version: '3.8'

# ASI:BUILD Production Docker Compose Stack
# Full production deployment with monitoring, logging, security, and scalability

services:
  # ============================================================================
  # CORE ASI:BUILD SERVICES
  # ============================================================================
  
  asi-build-core:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        BUILD_DATE: ${BUILD_DATE:-$(date -u +'%Y-%m-%dT%H:%M:%SZ')}
        VCS_REF: ${VCS_REF:-$(git rev-parse --short HEAD)}
        VERSION: ${VERSION:-latest}
    image: asi-build:${VERSION:-latest}
    container_name: asi-build-core
    restart: unless-stopped
    command: ["python", "-m", "asi_build_launcher"]
    environment:
      - ASI_BUILD_MODE=production
      - ASI_BUILD_SAFETY_LEVEL=maximum
      - ASI_BUILD_REALITY_LOCKED=true
      - ASI_BUILD_GOD_MODE=false
      - ASI_BUILD_HUMAN_OVERSIGHT=true
      - PYTHONPATH=/app
      - LOG_LEVEL=INFO
      - PROMETHEUS_ENDPOINT=http://prometheus:9090
      - GRAFANA_ENDPOINT=http://grafana:3000
      - ELASTICSEARCH_URL=http://elasticsearch:9200
    ports:
      - "8000:8000"  # Main API
      - "8001:8001"  # Admin API
      - "9091:9091"  # Metrics
    volumes:
      - asi_build_logs:/var/log/asi_build
      - asi_build_data:/var/lib/asi_build
      - asi_build_config:/etc/asi_build
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD", "/app/healthcheck.sh"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    deploy:
      resources:
        limits:
          memory: 32G
          cpus: '8'
        reservations:
          memory: 16G
          cpus: '4'
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    read_only: true
    tmpfs:
      - /tmp
      - /var/run
    depends_on:
      - redis
      - postgres
      - prometheus
      - elasticsearch

  # ASI:BUILD API Gateway
  asi-build-api:
    build:
      context: .
      dockerfile: Dockerfile
    image: asi-build:${VERSION:-latest}
    container_name: asi-build-api
    restart: unless-stopped
    command: ["python", "-m", "asi_build_api"]
    environment:
      - ASI_BUILD_MODE=api
      - API_HOST=0.0.0.0
      - API_PORT=8080
      - API_WORKERS=4
      - REDIS_URL=redis://redis:6379
      - DATABASE_URL=postgresql://asiuser:${POSTGRES_PASSWORD}@postgres:5432/asi_build
    ports:
      - "8080:8080"  # API Gateway
    volumes:
      - asi_build_logs:/var/log/asi_build
      - asi_build_config:/etc/asi_build
    networks:
      - asi-build-network
    depends_on:
      - asi-build-core
      - redis
      - postgres
    deploy:
      resources:
        limits:
          memory: 8G
          cpus: '4'
        reservations:
          memory: 4G
          cpus: '2'
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    read_only: true
    tmpfs:
      - /tmp
      - /var/run

  # ============================================================================
  # DATABASE SERVICES
  # ============================================================================

  postgres:
    image: postgres:15-alpine
    container_name: asi-build-postgres
    restart: unless-stopped
    environment:
      - POSTGRES_DB=asi_build
      - POSTGRES_USER=asiuser
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-asi_build_secure_password_2024}
      - POSTGRES_INITDB_ARGS="--auth-host=scram-sha-256"
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./scripts/init-db.sql:/docker-entrypoint-initdb.d/init.sql:ro
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U asiuser -d asi_build"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: '2'
        reservations:
          memory: 2G
          cpus: '1'

  redis:
    image: redis:7-alpine
    container_name: asi-build-redis
    restart: unless-stopped
    command: ["redis-server", "--appendonly", "yes", "--requirepass", "${REDIS_PASSWORD:-asi_build_redis_2024}"]
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD", "redis-cli", "--raw", "incr", "ping"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: '2'
        reservations:
          memory: 1G
          cpus: '0.5'

  # ============================================================================
  # MONITORING STACK
  # ============================================================================

  prometheus:
    image: prom/prometheus:latest
    container_name: asi-build-prometheus
    restart: unless-stopped
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/etc/prometheus/console_libraries'
      - '--web.console.templates=/etc/prometheus/consoles'
      - '--storage.tsdb.retention.time=30d'
      - '--web.enable-lifecycle'
      - '--web.enable-admin-api'
    ports:
      - "9090:9090"
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./monitoring/alert_rules.yml:/etc/prometheus/alert_rules.yml:ro
      - prometheus_data:/prometheus
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:9090/-/healthy"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: '2'
        reservations:
          memory: 2G
          cpus: '1'

  grafana:
    image: grafana/grafana:latest
    container_name: asi-build-grafana
    restart: unless-stopped
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_PASSWORD:-asi_build_grafana_2024}
      - GF_USERS_ALLOW_SIGN_UP=false
      - GF_SECURITY_ADMIN_USER=admin
      - GF_INSTALL_PLUGINS=grafana-piechart-panel,grafana-worldmap-panel
    ports:
      - "3000:3000"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./monitoring/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./monitoring/grafana/dashboards:/var/lib/grafana/dashboards:ro
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3000/api/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
    depends_on:
      - prometheus
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: '1'
        reservations:
          memory: 512M
          cpus: '0.5'

  alertmanager:
    image: prom/alertmanager:latest
    container_name: asi-build-alertmanager
    restart: unless-stopped
    command:
      - '--config.file=/etc/alertmanager/config.yml'
      - '--storage.path=/alertmanager'
      - '--web.external-url=http://localhost:9093'
    ports:
      - "9093:9093"
    volumes:
      - ./monitoring/alertmanager.yml:/etc/alertmanager/config.yml:ro
      - alertmanager_data:/alertmanager
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:9093/-/healthy"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 1G
          cpus: '1'
        reservations:
          memory: 256M
          cpus: '0.25'

  # ============================================================================
  # LOGGING STACK (ELK)
  # ============================================================================

  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0
    container_name: asi-build-elasticsearch
    restart: unless-stopped
    environment:
      - discovery.type=single-node
      - xpack.security.enabled=false
      - "ES_JAVA_OPTS=-Xms2g -Xmx2g"
    ports:
      - "9200:9200"
      - "9300:9300"
    volumes:
      - elasticsearch_data:/usr/share/elasticsearch/data
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:9200/_cluster/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: '2'
        reservations:
          memory: 2G
          cpus: '1'

  logstash:
    image: docker.elastic.co/logstash/logstash:8.11.0
    container_name: asi-build-logstash
    restart: unless-stopped
    volumes:
      - ./logging/logstash.conf:/usr/share/logstash/pipeline/logstash.conf:ro
      - asi_build_logs:/var/log/asi_build:ro
    networks:
      - asi-build-network
    depends_on:
      - elasticsearch
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: '1'
        reservations:
          memory: 1G
          cpus: '0.5'

  kibana:
    image: docker.elastic.co/kibana/kibana:8.11.0
    container_name: asi-build-kibana
    restart: unless-stopped
    environment:
      - ELASTICSEARCH_HOSTS=http://elasticsearch:9200
    ports:
      - "5601:5601"
    networks:
      - asi-build-network
    depends_on:
      - elasticsearch
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:5601/api/status || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: '1'
        reservations:
          memory: 1G
          cpus: '0.5'

  # ============================================================================
  # SECURITY & REVERSE PROXY
  # ============================================================================

  nginx:
    image: nginx:alpine
    container_name: asi-build-nginx
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/ssl:/etc/nginx/ssl:ro
      - nginx_logs:/var/log/nginx
    networks:
      - asi-build-network
    depends_on:
      - asi-build-api
      - grafana
      - kibana
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '1'
        reservations:
          memory: 256M
          cpus: '0.25'

  # ============================================================================
  # AUXILIARY SERVICES
  # ============================================================================

  # Message Queue for async processing
  rabbitmq:
    image: rabbitmq:3-management-alpine
    container_name: asi-build-rabbitmq
    restart: unless-stopped
    environment:
      - RABBITMQ_DEFAULT_USER=asiuser
      - RABBITMQ_DEFAULT_PASS=${RABBITMQ_PASSWORD:-asi_build_rabbit_2024}
    ports:
      - "5672:5672"
      - "15672:15672"  # Management UI
    volumes:
      - rabbitmq_data:/var/lib/rabbitmq
    networks:
      - asi-build-network
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 30s
      timeout: 10s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: '1'
        reservations:
          memory: 512M
          cpus: '0.25'

  # Celery worker for background tasks
  celery-worker:
    build:
      context: .
      dockerfile: Dockerfile
    image: asi-build:${VERSION:-latest}
    container_name: asi-build-celery-worker
    restart: unless-stopped
    command: ["celery", "-A", "asi_build.celery", "worker", "--loglevel=info", "--concurrency=4"]
    environment:
      - CELERY_BROKER_URL=pyamqp://asiuser:${RABBITMQ_PASSWORD:-asi_build_rabbit_2024}@rabbitmq:5672//
      - CELERY_RESULT_BACKEND=redis://redis:6379/1
    volumes:
      - asi_build_logs:/var/log/asi_build
      - asi_build_data:/var/lib/asi_build
    networks:
      - asi-build-network
    depends_on:
      - rabbitmq
      - redis
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: '2'
        reservations:
          memory: 2G
          cpus: '1'

  # Celery monitoring
  flower:
    build:
      context: .
      dockerfile: Dockerfile
    image: asi-build:${VERSION:-latest}
    container_name: asi-build-flower
    restart: unless-stopped
    command: ["celery", "-A", "asi_build.celery", "flower", "--port=5555"]
    environment:
      - CELERY_BROKER_URL=pyamqp://asiuser:${RABBITMQ_PASSWORD:-asi_build_rabbit_2024}@rabbitmq:5672//
      - CELERY_RESULT_BACKEND=redis://redis:6379/1
    ports:
      - "5555:5555"
    networks:
      - asi-build-network
    depends_on:
      - rabbitmq
      - celery-worker
    deploy:
      resources:
        limits:
          memory: 1G
          cpus: '0.5'
        reservations:
          memory: 256M
          cpus: '0.25'

# ============================================================================
# NETWORKS
# ============================================================================

networks:
  asi-build-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16

# ============================================================================
# VOLUMES
# ============================================================================

volumes:
  # Application data
  asi_build_logs:
    driver: local
  asi_build_data:
    driver: local
  asi_build_config:
    driver: local
  
  # Database volumes
  postgres_data:
    driver: local
  redis_data:
    driver: local
  
  # Monitoring volumes
  prometheus_data:
    driver: local
  grafana_data:
    driver: local
  alertmanager_data:
    driver: local
  
  # Logging volumes
  elasticsearch_data:
    driver: local
  
  # Message queue volumes
  rabbitmq_data:
    driver: local
  
  # Proxy logs
  nginx_logs:
    driver: local

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================

# Create a .env file with the following variables:
# POSTGRES_PASSWORD=your_secure_postgres_password
# REDIS_PASSWORD=your_secure_redis_password
# GRAFANA_PASSWORD=your_secure_grafana_password
# RABBITMQ_PASSWORD=your_secure_rabbitmq_password
# VERSION=latest
# BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
# VCS_REF=$(git rev-parse --short HEAD)

# ============================================================================
# DEPLOYMENT COMMANDS
# ============================================================================

# Development deployment:
# docker-compose up -d

# Production deployment:
# docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# Scaling services:
# docker-compose up -d --scale asi-build-core=3 --scale celery-worker=5

# Health check all services:
# docker-compose ps

# View logs:
# docker-compose logs -f asi-build-core

# Backup data:
# docker-compose exec postgres pg_dump -U asiuser asi_build > backup.sql

# Restore data:
# docker-compose exec -T postgres psql -U asiuser asi_build < backup.sql

# Update services:
# docker-compose pull
# docker-compose up -d --force-recreate

# Security scan:
# docker-compose run --rm asi-build-core python -m safety check
# docker-compose run --rm asi-build-core python -m bandit -r /app