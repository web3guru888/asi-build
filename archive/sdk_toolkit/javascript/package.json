{
  "name": "@kenny-agi/js-sdk",
  "version": "1.0.0",
  "description": "Kenny AGI RDK - JavaScript/TypeScript SDK for Artificial General Intelligence",
  "main": "kenny-sdk.js",
  "module": "kenny-sdk.esm.js",
  "types": "kenny-sdk.d.ts",
  "browser": "kenny-sdk.browser.js",
  "exports": {
    ".": {
      "import": "./kenny-sdk.esm.js",
      "require": "./kenny-sdk.js",
      "browser": "./kenny-sdk.browser.js",
      "types": "./kenny-sdk.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "kenny-sdk.js",
    "kenny-sdk.esm.js",
    "kenny-sdk.browser.js",
    "kenny-sdk.d.ts",
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:browser && npm run build:types",
    "build:cjs": "babel kenny-sdk.js --out-file dist/kenny-sdk.cjs.js --source-maps",
    "build:esm": "babel kenny-sdk.js --out-file dist/kenny-sdk.esm.js --source-maps --env-name esm",
    "build:browser": "webpack --config webpack.config.js",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir types",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.js",
    "lint": "eslint kenny-sdk.js --fix",
    "lint:check": "eslint kenny-sdk.js",
    "format": "prettier --write kenny-sdk.js",
    "format:check": "prettier --check kenny-sdk.js",
    "docs": "jsdoc kenny-sdk.js -d docs",
    "docs:serve": "http-server docs -p 8080",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist/ docs/ coverage/ types/",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "prepack": "npm run build",
    "dev": "nodemon --exec node examples/basic-usage.js",
    "benchmark": "node benchmarks/performance.js",
    "size": "bundlesize",
    "audit": "npm audit --audit-level moderate",
    "security": "npm audit && snyk test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kenny-agi/rdk.git",
    "directory": "sdk/javascript"
  },
  "keywords": [
    "agi",
    "artificial-intelligence",
    "consciousness",
    "reality-manipulation", 
    "quantum-computing",
    "javascript",
    "typescript",
    "sdk",
    "api-client",
    "websocket",
    "async",
    "browser",
    "nodejs",
    "kenny-agi",
    "rdk",
    "transcendence",
    "omniscience",
    "temporal-mechanics",
    "dimensional-portal"
  ],
  "author": {
    "name": "Kenny AGI Development Team",
    "email": "dev@kenny-agi.dev",
    "url": "https://kenny-agi.dev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kenny-agi/rdk/issues"
  },
  "homepage": "https://kenny-agi.dev/docs/javascript-sdk",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.0",
    "@babel/core": "^7.22.0", 
    "@babel/preset-env": "^7.22.0",
    "@types/node": "^20.5.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "bundlesize": "^0.18.0",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsdoc": "^46.5.0",
    "http-server": "^14.1.0",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "^29.6.0",
    "jsdoc": "^4.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "snyk": "^1.1200.0",
    "typescript": "^5.1.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "bundlesize": [
    {
      "path": "./dist/kenny-sdk.browser.js",
      "maxSize": "50 kB"
    },
    {
      "path": "./dist/kenny-sdk.esm.js",
      "maxSize": "45 kB"
    }
  ],
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "kenny-sdk.js",
      "!**/node_modules/**",
      "!**/coverage/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "env": {
      "node": true,
      "browser": true,
      "es2022": true
    },
    "rules": {
      "no-console": "warn",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/kenny-agi"
    },
    {
      "type": "opencollective", 
      "url": "https://opencollective.com/kenny-agi"
    }
  ],
  "directories": {
    "test": "tests",
    "doc": "docs",
    "example": "examples"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}