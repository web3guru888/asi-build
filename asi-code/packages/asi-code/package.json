{
  "name": "asi-code",
  "version": "0.2.0",
  "description": "ASI-Code - Advanced Software Intelligence Code Generation and Analysis Platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "asi-code": "./bin/asi-code.js",
    "asi": "./bin/asi-code.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./kenny": {
      "import": "./dist/kenny/index.js",
      "types": "./dist/kenny/index.d.ts"
    },
    "./provider": {
      "import": "./dist/provider/index.js",
      "types": "./dist/provider/index.d.ts"
    },
    "./tool": {
      "import": "./dist/tool/index.js",
      "types": "./dist/tool/index.d.ts"
    },
    "./session": {
      "import": "./dist/session/index.js",
      "types": "./dist/session/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./consciousness": {
      "import": "./dist/consciousness/index.js",
      "types": "./dist/consciousness/index.d.ts"
    },
    "./agent": {
      "import": "./dist/agent/index.js",
      "types": "./dist/agent/index.d.ts"
    },
    "./permission": {
      "import": "./dist/permission/index.js",
      "types": "./dist/permission/index.d.ts"
    },
    "./lsp": {
      "import": "./dist/lsp/index.js",
      "types": "./dist/lsp/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    },
    "./storage": {
      "import": "./dist/storage/index.js",
      "types": "./dist/storage/index.d.ts"
    },
    "./bus": {
      "import": "./dist/bus/index.js",
      "types": "./dist/bus/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./sat": {
      "import": "./dist/sat/index.js",
      "types": "./dist/sat/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run tsc && bun run build:bin",
    "build:bin": "bun build src/cli/index.ts --outdir bin --target node --format esm --outfile asi-code.js && chmod +x bin/asi-code.js",
    "dev": "bun run --watch src/server/server.ts",
    "dev:cli": "bun run --watch src/index.ts",
    "server": "bun src/server/server.ts",
    "server:watch": "bun run --watch src/server/server.ts",
    "start": "bun run dist/index.js",
    "test": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:performance": "vitest run --config vitest.performance.config.ts",
    "test:security": "npm audit && vitest run --config vitest.security.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:bun": "bun test",
    "test:bun:watch": "bun test --watch",
    "benchmark": "vitest bench",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "quality:check": "npm run version:check && npm run typecheck && npm run lint && npm run format:check",
    "quality:fix": "npm run lint:fix && npm run format",
    "quality:report": "node scripts/quality-check.cjs",
    "quality:dashboard": "npm run quality:report && echo 'Quality dashboard available at quality-reports/quality-report.html'",
    "docs:validate": "npm run docs:validate:api && npm run docs:validate:examples && npm run docs:coverage",
    "docs:validate:api": "node scripts/validate-api-docs.js",
    "docs:validate:examples": "node scripts/test-examples.js",
    "docs:validate:quick": "scripts/validate-examples-quick.sh",
    "docs:coverage": "node scripts/doc-coverage.js",
    "docs:freshness": "scripts/check-doc-freshness.sh",
    "docs:links": "scripts/check-doc-links.sh",
    "docs:report": "npm run docs:coverage && echo 'Documentation coverage report available at docs/validation-reports/'",
    "version:check": "node scripts/version-check.js",
    "version:bump": "node scripts/version-bump.js",
    "clean": "rm -rf dist bin node_modules coverage .nyc_output test-results",
    "typecheck": "tsc --noEmit",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:performance && npm run test:security",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "asi-code",
    "artificial-intelligence",
    "code-generation",
    "software-intelligence",
    "kenny-integration-pattern",
    "consciousness-engine",
    "agent-framework",
    "lsp",
    "mcp",
    "bun",
    "typescript"
  ],
  "author": "ASI Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@apollo/client": "^4.0.0",
    "@hono/node-server": "1.19.0",
    "@hono/node-ws": "^1.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.62.1",
    "@opentelemetry/exporter-jaeger": "^1.26.0",
    "@opentelemetry/resources": "2.0.1",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/semantic-conventions": "1.36.0",
    "@sentry/node": "^8.32.0",
    "@sentry/profiling-node": "10.5.0",
    "@types/node-cron": "3.0.11",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "12.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "eventemitter3": "^5.0.1",
    "express": "5.1.0",
    "glob": "^10.4.1",
    "graphql": "^16.11.0",
    "hono": "^4.4.8",
    "isomorphic-dompurify": "2.26.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "nanoid": "^5.0.7",
    "node-cron": "^3.0.3",
    "openai": "^4.52.0",
    "ora": "^8.0.1",
    "pg": "8.16.3",
    "pidusage": "^3.0.2",
    "prom-client": "^15.1.3",
    "semver": "^7.6.3",
    "subscriptions-transport-ws": "^0.11.0",
    "systeminformation": "^5.23.5",
    "uuid": "11.1.0",
    "ws": "^8.17.1",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.1.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "8.15.5",
    "@types/semver": "^7.5.8",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "0x": "^4.1.4",
    "autocannon": "^7.15.0",
    "clinic": "^9.1.0",
    "eslint": "^8.57.0",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "memfs": "^4.37.1",
    "playwright": "^1.44.1",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asi-team/asi-code.git"
  },
  "bugs": {
    "url": "https://github.com/asi-team/asi-code/issues"
  },
  "homepage": "https://github.com/asi-team/asi-code#readme"
}
