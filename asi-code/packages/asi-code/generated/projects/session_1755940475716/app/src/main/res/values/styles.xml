<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.DogExplorer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <!-- Background color for surfaces -->
        <item name="android:colorBackground">@android:color/white</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Window background -->
        <item name="android:windowBackground">@android:color/white</item>
        <!-- Text appearance -->
        <item name="textAppearanceBody1">@style/TextAppearance.DogExplorer.Body1</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.DogExplorer.Subtitle1</item>
    </style>

    <!-- Text Appearance Styles -->
    <style name="TextAppearance.DogExplorer.Headline">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">32sp</item>
    </style>

    <style name="TextAppearance.DogExplorer.Title">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">28sp</item>
    </style>

    <style name="TextAppearance.DogExplorer.Subtitle1">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="TextAppearance.DogExplorer.Body1">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="TextAppearance.DogExplorer.Caption">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
    </style>

    <!-- Custom Card View Style -->
    <style name="Widget.DogExplorer.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@android:color/white</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.DogExplorer.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/purple_500</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_height">48dp</item>
    </style>

    <style name="Widget.DogExplorer.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:layout_height">48dp</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.DogExplorer.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.DogExplorer.Title</item>
        <item name="navigationIconTint">@android:color/white</item>
    </style>

    <!-- Floating Action Button -->
    <style name="Widget.DogExplorer.FloatingActionButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="fabSize">normal</item>
        <item name="rippleColor">@color/purple_200</item>
        <item name="tint">@android:color/white</item>
    </style>

    <!-- Search View -->
    <style name="Widget.DogExplorer.SearchView" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/purple_500</item>
        <item name="hintTextColor">@color/purple_500</item>
        <item name="errorTextColor">@android:color/holo_red_dark</item>
    </style>
</resources>