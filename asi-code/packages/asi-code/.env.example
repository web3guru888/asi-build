# ASI-Code Environment Variables Template
# Copy this file to .env and fill in the actual values

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment (development, staging, production)
NODE_ENV=production

# Application configuration
ASI_CONFIG_PATH=./config/production.yml
APP_VERSION=1.0.0

# Server configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret - Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-here-change-this-in-production

# Encryption Key - Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-here-change-this-in-production

# API Keys for external services
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Connection
DATABASE_URL=postgresql://asicode:password@localhost:5432/asicode
POSTGRES_PASSWORD=secure-postgres-password-here

# Database pool configuration
DB_POOL_MIN=5
DB_POOL_MAX=20

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Redis Connection
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=secure-redis-password-here

# =============================================================================
# MONITORING AND OBSERVABILITY
# =============================================================================

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Jaeger tracing
JAEGER_ENDPOINT=http://localhost:14268/api/traces
JAEGER_SERVICE_NAME=asi-code
JAEGER_SAMPLER_TYPE=probabilistic
JAEGER_SAMPLER_PARAM=0.1

# Sentry error tracking
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# Grafana
GRAFANA_PASSWORD=secure-grafana-password-here

# =============================================================================
# CLOUD PROVIDER CONFIGURATION
# =============================================================================

# AWS Configuration (if using AWS services)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# S3 Backup Configuration
BACKUP_S3_BUCKET=asi-code-backups
BACKUP_S3_REGION=us-west-2

# =============================================================================
# KUBERNETES CONFIGURATION
# =============================================================================

# Kubernetes cluster configuration (for deployment scripts)
KUBE_CONFIG_PATH=~/.kube/config
KUBE_NAMESPACE=asi-code

# Container registry
REGISTRY_URL=ghcr.io
REGISTRY_USERNAME=your-github-username
REGISTRY_PASSWORD=your-github-token

# =============================================================================
# COMMUNICATION AND NOTIFICATIONS
# =============================================================================

# Slack notifications (optional)
SLACK_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook
SLACK_CHANNEL=#asi-code-alerts

# Email notifications (optional)
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=notifications@company.com
SMTP_PASSWORD=smtp-password-here
SMTP_FROM=ASI-Code <notifications@company.com>

# =============================================================================
# FEATURE FLAGS AND TOGGLES
# =============================================================================

# Enable/disable major features
KENNY_ENABLED=true
CONSCIOUSNESS_ENABLED=true
TOOLS_ENABLED=true
LEARNING_ENABLED=true

# Security features
AUTH_REQUIRED=true
RATE_LIMITING_ENABLED=true
AUDIT_LOGGING_ENABLED=true

# Development features (disable in production)
DEBUG_MODE=false
HOT_RELOAD_ENABLED=false
MOCK_SERVICES_ENABLED=false

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log format (pretty, json)
LOG_FORMAT=json

# Log destinations
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_FILE_PATH=/app/logs/asi-code.log

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Memory settings
MEMORY_THRESHOLD=2147483648  # 2GB
NODE_MAX_OLD_SPACE_SIZE=4096  # 4GB

# Cache settings
CACHE_TTL=3600  # 1 hour
CACHE_MAX_SIZE=1000

# Request timeout settings
REQUEST_TIMEOUT=30000  # 30 seconds
PROVIDER_TIMEOUT=30000  # 30 seconds

# =============================================================================
# BACKUP AND RECOVERY
# =============================================================================

# Backup configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# =============================================================================
# CORS AND SECURITY HEADERS
# =============================================================================

# CORS origins (comma-separated)
CORS_ORIGINS=https://asi-code.company.com,https://api.asi-code.company.com

# Security headers
HELMET_ENABLED=true
CSP_ENABLED=true

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
# These should only be used in development/staging environments

# Development database (use only in development)
# DEV_DATABASE_URL=postgresql://dev:dev@localhost:5432/asi_code_dev

# Development Redis (use only in development)
# DEV_REDIS_URL=redis://localhost:6379/0

# Mock API keys (use only in development)
# DEV_ANTHROPIC_API_KEY=mock-anthropic-key
# DEV_OPENAI_API_KEY=mock-openai-key

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. Never commit .env files with real secrets to version control
# 2. Use different values for each environment (dev, staging, production)
# 3. Rotate secrets regularly
# 4. Use your cloud provider's secret management service in production
# 5. Validate all environment variables on application startup
# 6. Use strong, unique passwords and keys
# 7. Enable all security features in production
# 8. Monitor and alert on configuration changes
# 
# =============================================================================