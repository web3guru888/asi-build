{
  "name": "asi-code",
  "version": "1.0.0",
  "description": "ASI-Code: Advanced AI Development Platform",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/asi-code dev",
    "build": "bun run --cwd packages/asi-code build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint packages/*/src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist packages/*/node_modules"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "dependencies": {
    "bun": "^1.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asi-build/asi-code.git"
  },
  "keywords": [
    "ai",
    "development",
    "platform",
    "asi",
    "automation"
  ],
  "author": "ASI Build",
  "license": "MIT"
}