# ASI_Code Environment Configuration

# ASI1 API Configuration
ASI1_API_KEY=your_asi1_api_key_here
ASI1_SESSION_ID=optional_session_id

# Default model (optional)
# Can be: asi1/asi1-mini, asi1/asi1-standard, asi1/asi1-pro, asi1/asi1-ultra, asi1/asi1-quantum
DEFAULT_MODEL=asi1/asi1-mini

# Other provider keys (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVEAI_API_KEY=

# Server configuration
OPENCODE_SERVER_PORT=8080

# Development mode
NODE_ENV=development