{
  "name": "@kenny-agi/wasm-sdk",
  "version": "1.0.0",
  "description": "Kenny AGI RDK - High-performance WebAssembly SDK for Artificial General Intelligence",
  "main": "kenny-wasm.js",
  "module": "kenny-wasm.js",
  "types": "kenny-wasm.d.ts",
  "files": [
    "kenny-wasm.js",
    "kenny-wasm.d.ts",
    "pkg/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg ../rust",
    "build:nodejs": "wasm-pack build --target nodejs --out-dir pkg-node ../rust",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler ../rust",
    "build:all": "npm run build && npm run build:nodejs && npm run build:bundler",
    "test": "npm run build && node test/test.js",
    "clean": "rm -rf pkg pkg-node pkg-bundler",
    "prepublishOnly": "npm run build:all",
    "dev": "npm run build && node examples/basic-usage.js",
    "benchmark": "npm run build && node benchmarks/performance.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kenny-agi/rdk.git",
    "directory": "sdk/wasm"
  },
  "keywords": [
    "agi",
    "artificial-intelligence", 
    "consciousness",
    "reality-manipulation",
    "quantum-computing",
    "wasm",
    "webassembly",
    "rust",
    "high-performance",
    "browser",
    "nodejs"
  ],
  "author": "Kenny AGI Development Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kenny-agi/rdk/issues"
  },
  "homepage": "https://kenny-agi.dev/docs/wasm-sdk",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "wasm-pack": "^0.12.0"
  },
  "peerDependencies": {
    "wasm-bindgen": "^0.2.0"
  },
  "browser": {
    "./kenny-wasm.js": "./kenny-wasm.js"
  },
  "exports": {
    ".": {
      "import": "./kenny-wasm.js",
      "require": "./kenny-wasm.js",
      "types": "./kenny-wasm.d.ts"
    },
    "./pkg": {
      "import": "./pkg/kenny_agi.js",
      "types": "./pkg/kenny_agi.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kenny-agi"
  },
  "config": {
    "wasm-opt": true,
    "target-features": [
      "+simd128",
      "+bulk-memory"
    ]
  }
}